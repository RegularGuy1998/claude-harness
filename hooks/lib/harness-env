#!/usr/bin/env bash
# Sourceable environment + helpers for claude-harness.
#
# Resolves plugin/data/project directories, target platform, the cached
# harness-cli binary path, the pinned release tag, and the release base URL.
# Provides functions to download+verify the binary, materialize a project's
# .harness/ workspace, run the CLI with the right env, and parse `query sql`
# output (which always emits a header + separator line before any data rows).
#
# Safe to source under `set -u`. No `set -e` (functions return status codes).

# ---------------------------------------------------------------------------
# Path resolution
# ---------------------------------------------------------------------------

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  HE_PLUGIN_ROOT="$CLAUDE_PLUGIN_ROOT"
else
  _he_lib_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  HE_PLUGIN_ROOT="$(cd "$_he_lib_dir/../.." && pwd)"
fi

if [ -n "${CLAUDE_PLUGIN_DATA:-}" ]; then
  HE_DATA_DIR="$CLAUDE_PLUGIN_DATA/claude-harness"
elif [ -n "${LOCALAPPDATA:-}" ]; then
  HE_DATA_DIR="$LOCALAPPDATA/claude-harness"
else
  HE_DATA_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude-harness"
fi

if [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
  HE_PROJECT_DIR="$CLAUDE_PROJECT_DIR"
elif _he_top="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  HE_PROJECT_DIR="$_he_top"
else
  HE_PROJECT_DIR="$PWD"
fi

# ---------------------------------------------------------------------------
# Platform / release resolution
# ---------------------------------------------------------------------------

he_is_windows() {
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) return 0 ;;
    *) return 1 ;;
  esac
}

# Print the release asset platform suffix; return 1 if unsupported.
he_detect_platform() {
  local os arch
  os="$(uname -s 2>/dev/null || echo unknown)"
  arch="$(uname -m 2>/dev/null || echo unknown)"
  case "$os" in
    MINGW*|MSYS*|CYGWIN*) printf 'windows-x64'; return 0 ;;
  esac
  case "$os:$arch" in
    Darwin:arm64)               printf 'macos-arm64' ;;
    Darwin:x86_64)              printf 'macos-x64' ;;
    Linux:x86_64)               printf 'linux-x64' ;;
    Linux:aarch64|Linux:arm64)  printf 'linux-arm64' ;;
    *) printf 'unsupported:%s:%s' "$os" "$arch"; return 1 ;;
  esac
}

he_release_tag() {
  local tag="${HARNESS_CLI_RELEASE_TAG:-}"
  if [ -z "$tag" ] && [ -f "$HE_PLUGIN_ROOT/scripts/harness-cli-release-tag" ]; then
    tag="$(awk 'NF && $1 !~ /^#/ { print $1; exit }' "$HE_PLUGIN_ROOT/scripts/harness-cli-release-tag")"
  fi
  printf '%s' "$tag"
}

# GitHub repo that hosts the harness-cli release assets (public). Override with
# HARNESS_CLI_RELEASE_REPO; the binary is built and published by this repo's CI.
he_release_repo() { printf '%s' "${HARNESS_CLI_RELEASE_REPO:-RegularGuy1998/claude-harness}"; }

he_base_url() {
  if [ -n "${HARNESS_CLI_BASE_URL:-}" ]; then
    printf '%s' "$HARNESS_CLI_BASE_URL"
    return
  fi
  local repo; repo="$(he_release_repo)"
  local tag; tag="$(he_release_tag)"
  if [ -n "$tag" ] && [ "$tag" != "latest" ]; then
    printf 'https://github.com/%s/releases/download/%s' "$repo" "$tag"
  else
    printf 'https://github.com/%s/releases/latest/download' "$repo"
  fi
}

# Absolute path to the cached binary (HARNESS_CLI_BIN overrides everything).
he_binary_path() {
  if [ -n "${HARNESS_CLI_BIN:-}" ]; then printf '%s' "$HARNESS_CLI_BIN"; return; fi
  local tag ext
  tag="$(he_release_tag)"; [ -n "$tag" ] || tag="latest"
  ext=""; he_is_windows && ext=".exe"
  printf '%s/bin/%s/harness-cli%s' "$HE_DATA_DIR" "$tag" "$ext"
}

he_sha256_file() {
  local f="$1"
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$f" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then shasum -a 256 "$f" | awk '{print $1}'
  elif command -v certutil >/dev/null 2>&1; then certutil -hashfile "$f" SHA256 | sed -n 2p | tr -d ' \r'
  else return 1; fi
}

# ---------------------------------------------------------------------------
# Binary bootstrap
# ---------------------------------------------------------------------------

# Download one release asset to a destination file. The repo is public, so the
# anonymous curl path alone is enough; gh and a token are tried first only when
# present (e.g. to dodge API rate limits or for a private mirror/fork). Order:
# gh CLI, then curl with a token (CI / GH_TOKEN), then anonymous curl
# (mirror via HARNESS_CLI_BASE_URL). Returns non-zero if every method fails.
he_download_asset() {
  local asset="$1" dest="$2"
  local tag; tag="$(he_release_tag)"
  # 1) gh CLI — used if present (also covers private mirrors/forks).
  if command -v gh >/dev/null 2>&1 && [ -n "$tag" ] && [ "$tag" != "latest" ]; then
    if gh release download "$tag" --repo "$(he_release_repo)" --pattern "$asset" \
         --output "$dest" --clobber >/dev/null 2>&1; then
      [ -s "$dest" ] && return 0
    fi
  fi
  command -v curl >/dev/null 2>&1 || return 1
  local url; url="$(he_base_url)/$asset"
  # 2) curl with a token if one is set (-L follows the signed redirect).
  local token="${GH_TOKEN:-${GITHUB_TOKEN:-}}"
  if [ -n "$token" ] \
     && curl -fsSL -H "Authorization: Bearer $token" "$url" -o "$dest" 2>/dev/null \
     && [ -s "$dest" ]; then
    return 0
  fi
  # 3) anonymous (mirror / public release).
  curl -fsSL "$url" -o "$dest" 2>/dev/null && [ -s "$dest" ]
}

# Ensure the binary is cached. Prints its path on success; returns non-zero on
# any failure (caller degrades to advisory mode). Idempotent.
he_ensure_binary() {
  local bin; bin="$(he_binary_path)"
  if [ -f "$bin" ]; then printf '%s' "$bin"; return 0; fi
  local platform; platform="$(he_detect_platform)" || return 1
  local ext=""; he_is_windows && ext=".exe"
  local asset="harness-cli-${platform}${ext}"
  local tmp; tmp="$(mktemp -d)" || return 1
  if ! he_download_asset "$asset" "$tmp/$asset" \
     || ! he_download_asset "$asset.sha256" "$tmp/$asset.sha256"; then
    rm -rf "$tmp"; return 1
  fi
  local expected actual
  expected="$(awk '{print $1; exit}' "$tmp/$asset.sha256")"
  actual="$(he_sha256_file "$tmp/$asset")" || { rm -rf "$tmp"; return 1; }
  if [ -z "$expected" ] || [ "$expected" != "$actual" ]; then rm -rf "$tmp"; return 1; fi
  mkdir -p "$(dirname "$bin")"
  cp "$tmp/$asset" "$bin" && chmod 755 "$bin" 2>/dev/null
  rm -rf "$tmp"
  [ -f "$bin" ] || return 1
  printf '%s' "$bin"; return 0
}

# ---------------------------------------------------------------------------
# Project workspace (.harness/)
# ---------------------------------------------------------------------------

he_harness_dir() { printf '%s/.harness' "$HE_PROJECT_DIR"; }
he_db_path()     { printf '%s/.harness/harness.db' "$HE_PROJECT_DIR"; }

he_have_binary() { [ -f "$(he_binary_path)" ]; }
he_have_db()     { [ -f "$(he_db_path)" ]; }

# Create .harness/ with the schema and a launcher wired to $1 (binary path).
# Idempotent; never touches an existing harness.db.
he_materialize_project() {
  local bin="$1"
  local hdir; hdir="$(he_harness_dir)"
  mkdir -p "$hdir/scripts/schema" || return 1
  cp -f "$HE_PLUGIN_ROOT"/scripts/schema/*.sql "$hdir/scripts/schema/" 2>/dev/null || true
  cat > "$hdir/harness" <<EOF
#!/usr/bin/env bash
# Auto-generated by claude-harness session-start. Do not edit.
export HARNESS_CLI_BIN="$bin"
export HARNESS_REPO_ROOT="$hdir"
export HARNESS_DB="$hdir/harness.db"
exec "\$HARNESS_CLI_BIN" "\$@"
EOF
  chmod 755 "$hdir/harness" 2>/dev/null || true
  if [ -f "$HE_PROJECT_DIR/.gitignore" ]; then
    grep -qxF '.harness/' "$HE_PROJECT_DIR/.gitignore" 2>/dev/null || printf '\n.harness/\n' >> "$HE_PROJECT_DIR/.gitignore"
  else
    printf '.harness/\n' > "$HE_PROJECT_DIR/.gitignore" 2>/dev/null || true
  fi
}

# ---------------------------------------------------------------------------
# Running the CLI + parsing `query sql`
# ---------------------------------------------------------------------------

# Run the CLI against the current project's DB. Returns the CLI's exit code.
he_cli() {
  HARNESS_REPO_ROOT="$(he_harness_dir)" HARNESS_DB="$(he_db_path)" "$(he_binary_path)" "$@"
}

# Print only the DATA rows of a `query sql` result (skip header + separator),
# with blank lines removed. `query sql` always prints a header line and a
# dashed separator line, so data starts at line 3.
he_sql_rows() {
  he_cli query sql "$1" 2>/dev/null | tail -n +3 | sed '/^[[:space:]]*$/d'
}

# Print the leading integer of the first data row (for COUNT(*) queries).
# Echoes 0 when there is no usable value.
he_sql_count() {
  local v
  v="$(he_sql_rows "$1" | head -n1 | tr -dc '0-9')"
  printf '%s' "${v:-0}"
}

# ---------------------------------------------------------------------------
# Project context-pack (onboarding) status
# ---------------------------------------------------------------------------

# Repo-relative committed context-pack the onboarding skill produces.
he_context_pack_path() { printf '%s/docs/context/PROJECT_CONTEXT.md' "$HE_PROJECT_DIR"; }

# Print a one-word status for the onboarding context-pack. FAIL-OPEN: any error
# degrades toward 'read' (if the file is there) or 'silent' (if not).
#   read        - pack file exists and matches the recorded hash; just read it
#   read-stale  - pack file exists but is unrecorded or its hash has drifted
#   onboard     - project opted in (DB present) but no pack file -> nudge
#   silent      - nothing to surface (not opted in and no pack file)
he_context_status() {
  local pack; pack="$(he_context_pack_path)"
  if [ -f "$pack" ]; then
    if he_have_binary && he_have_db; then
      local recorded current
      recorded="$(he_sql_rows "SELECT sha256 FROM project_context WHERE kind='pack' ORDER BY id DESC LIMIT 1" 2>/dev/null | head -n1 | tr -dc 'a-f0-9')"
      if [ -n "$recorded" ]; then
        current="$(he_sha256_file "$pack" 2>/dev/null | tr -dc 'a-f0-9')"
        if [ -n "$current" ] && [ "$current" = "$recorded" ]; then printf 'read'; return; fi
        printf 'read-stale'; return
      fi
      printf 'read-stale'; return   # file exists but the harness has no record of it
    fi
    printf 'read'; return
  fi
  if he_have_binary && he_have_db; then printf 'onboard'; return; fi
  printf 'silent'
}
